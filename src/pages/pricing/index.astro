---
import PricingPlans from '../../features/billing/components/PricingPlans';
import SEO from '../../components/SEO.astro';
---

<!DOCTYPE html>
<html lang="en" class="bg-[#030303]">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <SEO title="Pricing - Sentinel by BandhanNova" />
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  
  <script src="https://checkout.razorpay.com/v1/checkout.js" is:inline></script>

  <style>
    body {
      margin: 0;
      background-color: #030303;
      color: white;
      font-family: 'Inter', sans-serif;
    }
  </style>
</head>
<body class="min-h-screen relative overflow-x-hidden">
  {/* Background Orbs */}
  <div class="fixed inset-0 z-0 pointer-events-none">
    <div class="absolute top-[-20%] left-[-10%] w-[50%] h-[50%] bg-violet-600/10 blur-[150px] rounded-full"></div>
    <div class="absolute bottom-[-20%] right-[-10%] w-[50%] h-[50%] bg-fuchsia-600/10 blur-[150px] rounded-full"></div>
  </div>

  <div class="relative z-10 flex flex-col min-h-screen">
    {/* Simple Header */}
    <header class="h-20 border-b border-white/5 flex items-center px-8 backdrop-blur-md">
      <a href="/" class="flex items-center gap-3 hover:opacity-80 transition-opacity">
        <img src="/favicon.ico?v=2" alt="Sentinel Logo" class="w-10 h-10 object-contain drop-shadow-[0_0_12px_rgba(167,139,250,0.5)]" />
        <span class="text-2xl tracking-widest bg-clip-text text-transparent bg-gradient-to-r from-violet-400 to-fuchsia-400 drop-shadow-[0_0_2px_rgba(167,139,250,0.25)] mt-1" style="font-family: 'Virgo 01', sans-serif; letter-spacing: 2px;">
          Sentinel
        </span>
      </a>
      <div class="ml-auto flex items-center gap-6">
        <a href="/" class="text-sm font-semibold text-gray-400 hover:text-white transition-colors">Home</a>
        <a href="/docs" class="text-sm font-semibold text-gray-400 hover:text-white transition-colors">Docs</a>
        <a href="/signin" class="text-sm font-semibold text-gray-400 hover:text-white transition-colors">Sign In</a>
        <a href="/dashboard" class="px-4 py-2 rounded-xl bg-white/[0.05] border border-white/10 hover:bg-white/[0.1] text-xs font-semibold text-white transition-all">Go to Dashboard</a>
      </div>
    </header>

    <main class="flex-1 flex flex-col justify-center py-10">
      <PricingPlans client:load />
    </main>
  </div>
</body>
</html>
